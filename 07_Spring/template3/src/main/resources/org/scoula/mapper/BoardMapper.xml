<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- namespace는 반드시 경로 + 인터페이스 패키지명과 일치해야 함 -->
<mapper namespace="org.scoula.mapper.BoardMapper">
    <select id="selectAllByMapper" resultType="org.scoula.domain.BoardVO">
        <!-- CDATA 섹션: 안에 있는 내용은 하나의 문자열로 취급하겠다 -->
        <![CDATA[
            select * from tbl_board_ex
        ]]>
    </select>
</mapper>

