<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- namespace는 반드시 경로 + 인터페이스 패키지명과 일치해야 함 -->
<mapper namespace="org.scoula.board.mapper.BoardMapper">
<!--    <insert id="create" parameterType="BoardVO" useGeneratedKeys="true" keyProperty="no">-->
    <insert id="create">
        insert into tbl_board_ex(title, content, writer)
        values (#{title}, #{content}, #{writer})

        <!-- Select Key: auto_increment로 자동 생성된 PK값을 받을 수 있는 기능 -->
        <selectKey resultType="Long" keyProperty="no" keyColumn="no" order="AFTER">
            select last_insert_id()
        </selectKey>
    </insert>

    <!-- 첨부파일 저장 -->
    <insert id="createAttachment">
        insert into tbl_board_attachment_ex(filename, path, content_type, size, bno)
        values (#{filename}, #{path}, #{contentType}, #{size}, #{bno})
    </insert>

    <select id="getList" resultType="org.scoula.board.domain.BoardVO">
        select * from tbl_board_ex order by no desc
    </select>

<!--    <select id="get" parameterType="long" resultType="BoardVO">-->
<!--        select * from tbl_board_ex-->
<!--        where no = #{no}-->
<!--    </select>-->

    <!-- get v2 -->
    <select id="get" resultMap="boardMap">
        select b.*, a.no as ano, a.bno, a.filename, a.path,
            a.content_type, a.size, a.reg_date as a_reg_date
        from tbl_board_ex b
            left outer join tbl_board_attachment_ex a
                            on b.no = a.bno
        where b.no = #{no}
        order by filename
    </select>

    <!-- 첨부파일 단건 조회 -->
    <select id="getAttachment" resultType="org.scoula.board.domain.BoardAttachmentVO">
        select * from tbl_board_attachment_ex
        where no = #{no}
    </select>

    <select id="getAttachmentList" resultType="org.scoula.board.domain.BoardAttachmentVO">
        select *
        from tbl_board_attachment_ex
        where bno = #{bno}
        order by filename
    </select>

    <!-- 페이징 처리한 만큼 목록 조회 -->
    <select id="getPage" resultType="org.scoula.board.domain.BoardVO">
        select *
        from tbl_board_ex
        order by no desc
        limit #{offset}, #{amount}
    </select>

    <!-- 게시글 총 개수 조회-->
    <select id="getTotalCount" resultType="java.lang.Integer">
        select count(*) from tbl_board_ex
    </select>

    <!--
    ResultMap
    - DB 쿼리 결과의 컬럼과 자바 객체의 필드와 매핑
    - 일반적인 경우 (Camel <-> Snake) 변환 정도일 경우에는 MyBatis가 자동으로 매핑 해주지만,
    - Join과 같이 특수한 경우에는 직접 매핑이 필요함 (ResultMap)
    -->
    <resultMap id="boardMap" type="org.scoula.board.domain.BoardVO">
        <!-- id: 기본 키 매핑 태그 - MyBatis 객체의 동일성을 판단하고 캐싱/그룹핑할 때 사용 -->
        <id column="no"					property="no"/>
        <result column="title"			property="title"/>
        <result column="content"		property="content"/>
        <result column="writer"			property="writer"/>
        <result column="reg_date"		property="regDate"/>
        <result column="update_date"	property="updateDate"/>

        <!--
        collection: 1:N 관계 매핑
        - 조인 결과를 한번에 중첩 객체 형태로 만들어 줌 (BoardVO 안의 BoardAttachmentVO 형태)
        -->
        <collection property="attaches" resultMap="attachmentMap"/>
    </resultMap>

    <!-- BoardVO 내부의 BOardAttachmentVO에 매핑 -->
    <resultMap id="attachmentMap" type="org.scoula.board.domain.BoardAttachmentVO">
        <id column="ano" 				property="no"/>
        <result column="bno"   			property="bno"/>
        <result column="filename"		property="filename"/>
        <result column="path"			property="path"/>
        <result column="contentType"	property="contentType"/>
        <result column="size"       	property="size"/>
        <result column="a_reg_date" 	property="regDate"/>
    </resultMap>

    <update id="update">
        update tbl_board_ex
        set
            title = #{title},
            content = #{content},
            writer = #{writer},
            update_date = now()
        where no = #{no}
    </update>

    <delete id="delete">
        delete from tbl_board_ex where no = #{no}
    </delete>

    <delete id="deleteAttachment">
        delete
        from tbl_board_attachment_ex
        where no = #{no}
    </delete>
</mapper>

